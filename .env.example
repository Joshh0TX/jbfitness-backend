PORT=10000
NODE_ENV=development

# Database (Supabase Postgres)
# Use Supabase Transaction Pooler connection string in production.
DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@YOUR_SUPABASE_HOST:6543/postgres?sslmode=require
PGSSL=true

# Optional discrete PG vars (only if DATABASE_URL is not set)
# PGHOST=YOUR_SUPABASE_HOST
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=YOUR_DB_PASSWORD
# PGDATABASE=postgres

# Auth
JWT_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET

# External APIs
USDA_API_KEY=REPLACE_WITH_USDA_KEY
PAYSTACK_SECRET_KEY=REPLACE_WITH_PAYSTACK_SECRET
PAYSTACK_CALLBACK_URL=https://your-frontend-domain/settings
PAYSTACK_PREMIUM_MONTHLY_AMOUNT_KOBO=120000

# CORS
ALLOWED_ORIGINS=https://your-frontend-domain

# SMTP (Forgot password / OTP)
SMTP_SERVICE=gmail
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=REPLACE_WITH_SMTP_APP_PASSWORD
SMTP_FROM=your-email@example.com
SMTP_FORCE_IPV4=true
SMTP_CONNECTION_TIMEOUT_MS=15000
SMTP_GREETING_TIMEOUT_MS=15000
SMTP_SOCKET_TIMEOUT_MS=20000
EMAIL_SEND_TIMEOUT_MS=20000
FRONTEND_URL=https://your-frontend-domain

# OpenTelemetry
OTEL_ENABLED=false
OTEL_SERVICE_NAME=jbfitness-backend
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=https://your-otel-collector
OTEL_API_KEY=REPLACE_WITH_OTEL_API_KEY
OTEL_METRIC_EXPORT_INTERVAL=10000
OTEL_DIAGNOSTIC_LOG_LEVEL=INFO
